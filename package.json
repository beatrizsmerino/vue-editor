{
	"version": "3.5.4",
	"private": true,
	"name": "vue-editor",
	"description": "Editor online of code made with Vue.",
	"author": {
		"name": "Beatriz Sopeña Merino",
		"email": "beatrizsmerino@gmail.com",
		"url": "https://github.com/beatrizsmerino"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/beatrizsmerino/vue-editor.git"
	},
	"homepage": "https://beatrizsmerino.github.io/vue-editor",
	"bugs": {
		"url": "https://github.com/beatrizsmerino/vue-editor/issues"
	},
	"keywords": [
		"vue",
		"vite",
		"javascript",
		"editor",
		"json"
	],
	"main": "index.js",
	"type": "module",
	"scripts": {
		"install:clean": "rm -rf node_modules package-lock.json",
		"postinstall": "npm run lint",
		"prepare": "husky",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"prettier:fix": "prettier --write './**/*.{css,scss,json,yml,yaml,js,cjs,mjs,vue}'",
		"eslint:fix": "eslint './**/*.{json,js,cjs,mjs,vue}' --fix --ignore-path .eslintignore",
		"stylelint:fix": "stylelint './**/*.{css,scss,vue}' --fix --ignore-path .stylelintignore",
		"lint": "npm run prettier:fix && npm run eslint:fix && npm run stylelint:fix",
		"deploy": "node gh-pages-deploy.js"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"execa": "^9.6.1",
		"json-editor-vue": "^0.18.1",
		"node-emoji": "^2.2.0",
		"v-clipboard": "^3.0.0-next.1",
		"vite-plugin-svg-icons": "^2.0.1",
		"vue": "^3.5.30",
		"vue-router": "^5.0.6",
		"vuex": "^4.1.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vue/eslint-config-prettier": "^10.2.0",
		"eslint": "^8.57.0",
		"eslint-plugin-json": "^3.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "10.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"postcss": "^8.5.12",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"stylelint": "^17.9.0",
		"stylelint-config-property-sort-order-smacss": "^11.2.0",
		"stylelint-config-recommended-vue": "^1.6.1",
		"stylelint-config-sass-guidelines": "^12.1.0",
		"stylelint-config-standard": "^39.0.1",
		"stylelint-scss": "^6.14.0",
		"vite": "^8.0.10"
	},
	"engines": {
		"node": "24.15.0",
		"npm": "11.12.1"
	},
	"overrides": {
		"stylelint-config-recommended-vue": {
			"stylelint-config-recommended": "17.0.0"
		},
		"vite-plugin-svg-icons": {
			"micromatch": "^4.0.8",
			"postcss": "^8.5.8"
		}
	}
}
